{
  "name": "subfission/cas",
  "description": "Adds CAS support to Laravel 5.x - 13.x",
  "keywords": [
    "CAS",
    "phpCAS",
    "SSO",
    "laravel",
    "laravel 6",
    "laravel 7",
    "laravel 8",
    "laravel 9",
    "laravel 10",
    "laravel 11",
    "laravel 12",
    "laravel 13"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "subfission",
      "role": "Developer"
    }
  ],
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/EsupPortail/phpCAS.git",
      "reference": "master"
    }
  ],
  "require": {
    "php": ">=7.2.0",
    "laravel/framework": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
    "apereo/phpcas": "dev-master@dev",
    "monolog/monolog": "^2.0|^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^8.0|^9.0|^10.0|^11.0|^12.0",
    "pestphp/pest": "^4.0",
    "fakerphp/faker": "^1.9"
  },
  "autoload": {
    "psr-4": {
      "Subfission\\Cas\\": "src/Subfission/Cas/"
    },
    "files": [
      "src/Subfission/Cas/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Subfission\\Cas\\Tests\\": "tests"
    }
  },
  "minimum-stability": "stable",
  "extra": {
    "laravel": {
      "providers": [
        "Subfission\\Cas\\CasServiceProvider"
      ],
      "aliases": {
        "Cas": "Subfission\\Cas\\Facades\\Cas"
      }
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}